generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String   @id @default(cuid())
  email    String   @unique
  passwordHash    String
  role     UserRole
  children Child[]
  trainerGroups TrainerGroup[]

  createdAt DateTime @default(now())
}

model Group {
  id        String   @id @default(cuid())
  name      String
  location  String?

  children  Child[]
  trainers  TrainerGroup[]

  createdAt DateTime @default(now())
}

model TrainerGroup {
  trainerId String
  groupId   String
  trainer   User  @relation(fields: [trainerId], references: [id])
  group     Group @relation(fields: [groupId], references: [id])

  assignedAt DateTime @default(now())

  @@id([trainerId, groupId])
}

model Child {
  id        String   @id @default(cuid())
  name      String
  birthYear Int
  groupId   String
  group     Group   @relation(fields: [groupId], references: [id])

  parentId String
  parent   User   @relation(fields: [parentId], references: [id])

  results TestResult[]

  createdAt DateTime @default(now())
}

model TestResult {
  id      String @id @default(cuid())
  childId String
  child   Child  @relation(fields: [childId], references: [id])

  testType String
  value    Float
  unit     String
  testedAt DateTime

  createdAt DateTime @default(now())
}

enum UserRole {
  PARENT
  TRAINER
}
