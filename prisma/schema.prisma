generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String   @id @default(cuid())
  email    String   @unique
  passwordHash    String
  role     UserRole
  children Child[]
  trainerGroups TrainerGroup[]
  passwordResetTokens PasswordResetToken[]

  mustChangePassword Boolean @default(false)
  createdAt DateTime @default(now())
}

model Group {
  id        String   @id @default(cuid())
  name      String
  location  String?

  children  Child[]
  trainers  TrainerGroup[]

  createdAt DateTime @default(now())
}

model TrainerGroup {
  trainerId String
  groupId   String
  trainer   User  @relation(fields: [trainerId], references: [id])
  group     Group @relation(fields: [groupId], references: [id])

  assignedAt DateTime @default(now())

  @@id([trainerId, groupId])
}

model Child {
  id        String   @id @default(cuid())
  name      String
  birthYear Int
  groupId   String
  group     Group   @relation(fields: [groupId], references: [id])

  parentId String
  parent   User   @relation(fields: [parentId], references: [id])

  results TestResult[]

  createdAt DateTime @default(now())
}

model TestResult {
  id      String @id @default(cuid())
  childId String
  child   Child  @relation(fields: [childId], references: [id])

  testType String
  value    Float
  unit     String
  testedAt DateTime

  createdAt DateTime @default(now())
}

model LoginAttempt {
  id          String   @id @default(cuid())
  key         String
  email       String?
  ip          String?
  windowStart DateTime
  count       Int      @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, windowStart], name: "key_windowStart")
  @@index([email])
  @@index([ip])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tokenHash])
}

enum UserRole {
  PARENT
  TRAINER
}
